{
  "name": "youtube-downloader-desktop",
  "version": "1.1.0",
  "description": "A polished Windows desktop app for downloading YouTube videos, audio, and playlists.",
  "author": "Magnitoshka",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Magnitoshka/AetherFLow.git"
  },
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "start": "electron .",
    "build": "vite build",
    "test": "node --test tests/*.test.js",
    "dist": "electron-builder --win nsis",
    "landing:copy": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/copy-landing-build.ps1"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3"
  },
  "build": {
    "appId": "com.local.youtubedownloader",
    "productName": "AetherFlow",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
